# PocketBase Instant Backend — Environment Variables
# Copy to .env for local dev. Set in Railway Dashboard for production.

# Public port (Railway injects automatically)
# PORT=8080

# PocketBase internal port (not exposed externally)
# PB_INTERNAL_PORT=8090

# Encryption key for stored secrets
# Generate: openssl rand -base64 32
# PB_ENCRYPTION_KEY=

# Auto-create admin on first deploy
# PB_ADMIN_EMAIL=admin@example.com
# PB_ADMIN_PASSWORD=change-me-please

# Data directory (SQLite + files + settings)
# PB_DATA_DIR=/pb_data
