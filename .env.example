# ============================================
# PocketBase on Railway - Environment Variables
# ============================================
# Copy this file to .env for local development.
# On Railway, set these in the Service Variables panel.

# ---- Railway-injected (auto-set, no need to configure) ----
# PORT=8080

# ---- Security ----
# Encryption key for securing stored data.
# PocketBase reads this via the PB_ENCRYPTION_KEY env var.
# Generate one: openssl rand -base64 32
# PB_ENCRYPTION_KEY=

# ---- Optional: Auto-create admin on first deploy ----
# Set both to create an admin automatically.
# Otherwise, create your admin through the web UI at /_/
# PB_ADMIN_EMAIL=admin@example.com
# PB_ADMIN_PASSWORD=change-me-please

# ---- CORS (configure in PocketBase admin panel) ----
# After deploy, go to the admin UI > Settings to configure CORS.
# For frontend apps, set the allowed origin to your frontend URL.

# ---- Health Sidecar ----
# SIDECAR_PORT=8090
